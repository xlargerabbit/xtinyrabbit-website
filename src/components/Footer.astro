---
const year = new Date().getFullYear();
---

<footer>
  <div class="container footer-inner">
    <span class="copy">© {year} xtinyrabbit</span>
    <div class="links">
      <a href="/rss.xml" aria-label="RSS feed">RSS</a>
      <a href="https://github.com/xlargerabbit" target="_blank" rel="noopener">GitHub</a>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    padding-block: 2rem;
    margin-top: 6rem;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .copy, .links a {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .links { display: flex; gap: 1.5rem; }
  .links a:hover { color: var(--color-text); text-decoration: none; }
</style>
