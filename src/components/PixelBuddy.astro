      <rect x="12" y="18" width="3" height="3" fill="currentColor"/>
      <rect x="15" y="18" width="3" height="3" fill="currentColor"/>
      <rect x="18" y="18" width="3" height="3" fill="currentColor"/>
      <rect x="21" y="18" width="3" height="3" fill="currentColor"/>
