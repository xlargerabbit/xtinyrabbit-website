      <rect x="15" y="21" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="18" y="21" width="3" height="3" fill="var(--color-bg)"/>

      <!-- Ears -->
      <rect x="33" y="0"  width="3" height="3" fill="currentColor"/>
      <rect x="27" y="0"  width="3" height="3" fill="currentColor"/>
      <rect x="21" y="0"  width="3" height="3" fill="currentColor"/>
      <rect x="15" y="0"  width="3" height="3" fill="currentColor"/>
      <rect x="9"  y="0"  width="3" height="3" fill="currentColor"/>
      <rect x="30" y="3"  width="3" height="3" fill="currentColor"/>
      <rect x="24" y="3"  width="3" height="3" fill="currentColor"/>
      <rect x="18" y="3"  width="3" height="3" fill="currentColor"/>
      <rect x="12" y="3"  width="3" height="3" fill="currentColor"/>
      <rect x="27" y="0"  width="3" height="3" fill="var(--color-accent)"/>
      <rect x="21" y="0"  width="3" height="3" fill="var(--color-accent)"/>
      <rect x="15" y="0"  width="3" height="3" fill="var(--color-accent)"/>
      <rect x="24" y="3"  width="3" height="3" fill="var(--color-accent)"/>
      <rect x="18" y="3"  width="3" height="3" fill="var(--color-accent)"/>
