      <rect x="12" y="21" width="3" height="3" fill="currentColor"/>
      <rect x="15" y="21" width="3" height="3" fill="currentColor"/>
      <rect x="18" y="21" width="3" height="3" fill="currentColor"/>
      <rect x="21" y="21" width="3" height="3" fill="currentColor"/>
      <rect x="24" y="21" width="3" height="3" fill="currentColor"/>
      <rect x="27" y="21" width="3" height="3" fill="currentColor"/>

      <!-- Belly -->
      <rect x="9"  y="15" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="12" y="15" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="15" y="15" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="18" y="15" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="21" y="15" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="9"  y="18" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="12" y="18" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="15" y="18" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="18" y="18" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="21" y="18" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="9"  y="21" width="3" height="3" fill="var(--color-bg)"/>
