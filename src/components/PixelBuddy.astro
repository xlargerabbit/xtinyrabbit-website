---
// PixelBuddy.astro — decorative animated rabbit that periodically runs across the viewport
---

<div id="pixel-buddy" aria-hidden="true" role="presentation">
  <!--
    Pixel-art rabbit, 16×12 grid (each cell = 3px), viewBox 0 0 48 36.
    Rabbit faces RIGHT. Ears swept back toward col 0 (left).
    Head is at cols 10–15 (right side). Tail is at cols 0–1 (left).
    4 frames for a gallop cycle: stride-A, gather, stride-B, gather.
  -->
  <svg id="rabbit-sprite" data-frame="0" width="48" height="36" viewBox="0 0 48 36" style="overflow:visible">

    <!-- ═══════════════ FRAME 0 — stride A ═══════════════ -->
    <g class="frame-0">
      <!-- Tail (cols 0–1, rows 5–6) -->
      <rect x="0"  y="15" width="3" height="3" fill="currentColor"/>
      <rect x="3"  y="15" width="3" height="3" fill="currentColor"/>
      <rect x="0"  y="18" width="3" height="3" fill="currentColor"/>
      <rect x="3"  y="18" width="3" height="3" fill="currentColor"/>

      <!-- Body (cols 2–9, rows 4–7) -->
      <rect x="6"  y="12" width="3" height="3" fill="currentColor"/>
      <rect x="9"  y="12" width="3" height="3" fill="currentColor"/>
      <rect x="12" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="15" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="18" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="21" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="24" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="27" y="12" width="3" height="3" fill="currentColor"/>

      <rect x="6"  y="15" width="3" height="3" fill="currentColor"/>
      <rect x="9"  y="15" width="3" height="3" fill="currentColor"/>
      <rect x="12" y="15" width="3" height="3" fill="currentColor"/>
      <rect x="15" y="15" width="3" height="3" fill="currentColor"/>
      <rect x="18" y="15" width="3" height="3" fill="currentColor"/>
      <rect x="21" y="15" width="3" height="3" fill="currentColor"/>
      <rect x="24" y="15" width="3" height="3" fill="currentColor"/>
      <rect x="27" y="15" width="3" height="3" fill="currentColor"/>

      <rect x="6"  y="18" width="3" height="3" fill="currentColor"/>
      <rect x="9"  y="18" width="3" height="3" fill="currentColor"/>
      <rect x="12" y="18" width="3" height="3" fill="currentColor"/>
      <rect x="15" y="18" width="3" height="3" fill="currentColor"/>
      <rect x="18" y="18" width="3" height="3" fill="currentColor"/>
      <rect x="21" y="18" width="3" height="3" fill="currentColor"/>
      <rect x="24" y="18" width="3" height="3" fill="currentColor"/>
      <rect x="27" y="18" width="3" height="3" fill="currentColor"/>

      <rect x="6"  y="21" width="3" height="3" fill="currentColor"/>
      <rect x="9"  y="21" width="3" height="3" fill="currentColor"/>
      <rect x="12" y="21" width="3" height="3" fill="currentColor"/>
      <rect x="15" y="21" width="3" height="3" fill="currentColor"/>
      <rect x="18" y="21" width="3" height="3" fill="currentColor"/>
      <rect x="21" y="21" width="3" height="3" fill="currentColor"/>
      <rect x="24" y="21" width="3" height="3" fill="currentColor"/>
      <rect x="27" y="21" width="3" height="3" fill="currentColor"/>

      <!-- Belly (cols 3–8, rows 5–7) -->
      <rect x="9"  y="15" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="12" y="15" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="15" y="15" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="18" y="15" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="21" y="15" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="9"  y="18" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="12" y="18" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="15" y="18" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="18" y="18" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="21" y="18" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="9"  y="21" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="12" y="21" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="15" y="21" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="18" y="21" width="3" height="3" fill="var(--color-bg)"/>

      <!-- Ears (swept back toward left, rows 0–2) -->
      <!-- Outer ear base at head (cols 11–13), sweeping to col 3 -->
      <rect x="33" y="0"  width="3" height="3" fill="currentColor"/>
      <rect x="27" y="0"  width="3" height="3" fill="currentColor"/>
      <rect x="21" y="0"  width="3" height="3" fill="currentColor"/>
      <rect x="15" y="0"  width="3" height="3" fill="currentColor"/>
      <rect x="9"  y="0"  width="3" height="3" fill="currentColor"/>
      <rect x="30" y="3"  width="3" height="3" fill="currentColor"/>
      <rect x="24" y="3"  width="3" height="3" fill="currentColor"/>
      <rect x="18" y="3"  width="3" height="3" fill="currentColor"/>
      <rect x="12" y="3"  width="3" height="3" fill="currentColor"/>
      <!-- Inner ear accent -->
      <rect x="27" y="0"  width="3" height="3" fill="var(--color-accent)"/>
      <rect x="21" y="0"  width="3" height="3" fill="var(--color-accent)"/>
      <rect x="15" y="0"  width="3" height="3" fill="var(--color-accent)"/>
      <rect x="24" y="3"  width="3" height="3" fill="var(--color-accent)"/>
      <rect x="18" y="3"  width="3" height="3" fill="var(--color-accent)"/>

      <!-- Second ear (slightly lower, rows 1–3) -->
      <rect x="36" y="3"  width="3" height="3" fill="currentColor"/>
      <rect x="33" y="3"  width="3" height="3" fill="currentColor"/>
      <rect x="30" y="6"  width="3" height="3" fill="currentColor"/>
      <rect x="24" y="6"  width="3" height="3" fill="currentColor"/>
      <rect x="18" y="6"  width="3" height="3" fill="currentColor"/>
      <!-- Inner ear 2 accent -->
      <rect x="30" y="6"  width="3" height="3" fill="var(--color-accent)"/>
      <rect x="24" y="6"  width="3" height="3" fill="var(--color-accent)"/>

      <!-- Head (cols 10–15, rows 2–5) -->
      <rect x="30" y="6"  width="3" height="3" fill="currentColor"/>
      <rect x="33" y="6"  width="3" height="3" fill="currentColor"/>
      <rect x="36" y="6"  width="3" height="3" fill="currentColor"/>
      <rect x="39" y="6"  width="3" height="3" fill="currentColor"/>
      <rect x="42" y="6"  width="3" height="3" fill="currentColor"/>
      <rect x="45" y="6"  width="3" height="3" fill="currentColor"/>
      <rect x="30" y="9"  width="3" height="3" fill="currentColor"/>
      <rect x="33" y="9"  width="3" height="3" fill="currentColor"/>
      <rect x="36" y="9"  width="3" height="3" fill="currentColor"/>
      <rect x="39" y="9"  width="3" height="3" fill="currentColor"/>
      <rect x="42" y="9"  width="3" height="3" fill="currentColor"/>
      <rect x="45" y="9"  width="3" height="3" fill="currentColor"/>
      <rect x="30" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="33" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="36" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="39" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="42" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="45" y="12" width="3" height="3" fill="currentColor"/>

      <!-- Eye (col 14, row 3) — eye-white then pupil -->
      <rect x="42" y="9"  width="3" height="3" fill="var(--color-bg)"/>
      <rect x="42" y="9"  width="2" height="2" fill="currentColor"/>

      <!-- Nose (col 15, row 4) -->
      <rect x="45" y="12" width="3" height="3" fill="var(--color-accent)"/>

      <!-- Front legs — stride A: forward (cols 11–13, rows 9–11) -->
      <rect x="33" y="24" width="3" height="3" fill="currentColor"/>
      <rect x="36" y="24" width="3" height="3" fill="currentColor"/>
      <rect x="39" y="24" width="3" height="3" fill="currentColor"/>
      <rect x="33" y="27" width="3" height="3" fill="currentColor"/>
      <rect x="36" y="27" width="3" height="3" fill="currentColor"/>
      <rect x="39" y="27" width="3" height="3" fill="currentColor"/>
      <rect x="33" y="30" width="3" height="3" fill="currentColor"/>
      <rect x="36" y="30" width="3" height="3" fill="currentColor"/>

      <!-- Back legs — stride A: back (cols 1–3, rows 9–11) -->
      <rect x="3"  y="24" width="3" height="3" fill="currentColor"/>
      <rect x="6"  y="24" width="3" height="3" fill="currentColor"/>
      <rect x="9"  y="24" width="3" height="3" fill="currentColor"/>
      <rect x="3"  y="27" width="3" height="3" fill="currentColor"/>
      <rect x="6"  y="27" width="3" height="3" fill="currentColor"/>
      <rect x="9"  y="27" width="3" height="3" fill="currentColor"/>
      <rect x="6"  y="30" width="3" height="3" fill="currentColor"/>
      <rect x="9"  y="30" width="3" height="3" fill="currentColor"/>
    </g>

    <!-- ═══════════════ FRAME 1 — gather (crouch) ═══════════════ -->
    <g class="frame-1">
      <!-- Tail -->
      <rect x="0"  y="18" width="3" height="3" fill="currentColor"/>
      <rect x="3"  y="18" width="3" height="3" fill="currentColor"/>
      <rect x="0"  y="21" width="3" height="3" fill="currentColor"/>
      <rect x="3"  y="21" width="3" height="3" fill="currentColor"/>

      <!-- Body (shifted +1 row down to imply crouch) -->
      <rect x="6"  y="15" width="3" height="3" fill="currentColor"/>
      <rect x="9"  y="15" width="3" height="3" fill="currentColor"/>
      <rect x="12" y="15" width="3" height="3" fill="currentColor"/>
      <rect x="15" y="15" width="3" height="3" fill="currentColor"/>
      <rect x="18" y="15" width="3" height="3" fill="currentColor"/>
      <rect x="21" y="15" width="3" height="3" fill="currentColor"/>
      <rect x="24" y="15" width="3" height="3" fill="currentColor"/>
      <rect x="27" y="15" width="3" height="3" fill="currentColor"/>

      <rect x="6"  y="18" width="3" height="3" fill="currentColor"/>
      <rect x="9"  y="18" width="3" height="3" fill="currentColor"/>
      <rect x="12" y="18" width="3" height="3" fill="currentColor"/>
      <rect x="15" y="18" width="3" height="3" fill="currentColor"/>
      <rect x="18" y="18" width="3" height="3" fill="currentColor"/>
      <rect x="21" y="18" width="3" height="3" fill="currentColor"/>
      <rect x="24" y="18" width="3" height="3" fill="currentColor"/>
      <rect x="27" y="18" width="3" height="3" fill="currentColor"/>

      <rect x="6"  y="21" width="3" height="3" fill="currentColor"/>
      <rect x="9"  y="21" width="3" height="3" fill="currentColor"/>
      <rect x="12" y="21" width="3" height="3" fill="currentColor"/>
      <rect x="15" y="21" width="3" height="3" fill="currentColor"/>
      <rect x="18" y="21" width="3" height="3" fill="currentColor"/>
      <rect x="21" y="21" width="3" height="3" fill="currentColor"/>
      <rect x="24" y="21" width="3" height="3" fill="currentColor"/>
      <rect x="27" y="21" width="3" height="3" fill="currentColor"/>

      <!-- Belly -->
      <rect x="9"  y="18" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="12" y="18" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="15" y="18" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="18" y="18" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="21" y="18" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="9"  y="21" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="12" y="21" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="15" y="21" width="3" height="3" fill="var(--color-bg)"/>
      <rect x="18" y="21" width="3" height="3" fill="var(--color-bg)"/>

      <!-- Ears -->
      <rect x="33" y="0"  width="3" height="3" fill="currentColor"/>
      <rect x="27" y="0"  width="3" height="3" fill="currentColor"/>
      <rect x="21" y="0"  width="3" height="3" fill="currentColor"/>
      <rect x="15" y="0"  width="3" height="3" fill="currentColor"/>
      <rect x="9"  y="0"  width="3" height="3" fill="currentColor"/>
      <rect x="30" y="3"  width="3" height="3" fill="currentColor"/>
      <rect x="24" y="3"  width="3" height="3" fill="currentColor"/>
      <rect x="18" y="3"  width="3" height="3" fill="currentColor"/>
      <rect x="12" y="3"  width="3" height="3" fill="currentColor"/>
      <rect x="27" y="0"  width="3" height="3" fill="var(--color-accent)"/>
      <rect x="21" y="0"  width="3" height="3" fill="var(--color-accent)"/>
      <rect x="15" y="0"  width="3" height="3" fill="var(--color-accent)"/>
      <rect x="24" y="3"  width="3" height="3" fill="var(--color-accent)"/>
      <rect x="18" y="3"  width="3" height="3" fill="var(--color-accent)"/>
      <rect x="36" y="3"  width="3" height="3" fill="currentColor"/>
      <rect x="33" y="3"  width="3" height="3" fill="currentColor"/>
      <rect x="30" y="6"  width="3" height="3" fill="currentColor"/>
      <rect x="24" y="6"  width="3" height="3" fill="currentColor"/>
      <rect x="18" y="6"  width="3" height="3" fill="currentColor"/>
      <rect x="30" y="6"  width="3" height="3" fill="var(--color-accent)"/>
      <rect x="24" y="6"  width="3" height="3" fill="var(--color-accent)"/>

      <!-- Head (shifted +1 row) -->
      <rect x="30" y="9"  width="3" height="3" fill="currentColor"/>
      <rect x="33" y="9"  width="3" height="3" fill="currentColor"/>
      <rect x="36" y="9"  width="3" height="3" fill="currentColor"/>
      <rect x="39" y="9"  width="3" height="3" fill="currentColor"/>
      <rect x="42" y="9"  width="3" height="3" fill="currentColor"/>
      <rect x="45" y="9"  width="3" height="3" fill="currentColor"/>
      <rect x="30" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="33" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="36" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="39" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="42" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="45" y="12" width="3" height="3" fill="currentColor"/>
      <rect x="30" y="15" width="3" height="3" fill="currentColor"/>
      <rect x="33" y="15" width="3" height="3" fill="currentColor"/>
      <rect x="36" y="15" width="3" height="3" fill="currentColor"/>
