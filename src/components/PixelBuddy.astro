<style>
  #pixel-buddy {
    position: fixed;
    top: var(--header-height);
    left: 50vw;
    z-index: 49;
    pointer-events: none;
    transform: translateX(-200vw);
  }

  #rabbit-sprite {
    color: var(--color-text);
    display: block;
  }

  /* Frame visibility — default all frames hidden, show the active frame */
  .frame-0, .frame-1, .frame-2, .frame-3 { display: none; }
  #rabbit-sprite[data-frame="0"] .frame-0 { display: block; }
  #rabbit-sprite[data-frame="1"] .frame-1 { display: block; }
  #rabbit-sprite[data-frame="2"] .frame-2 { display: block; }
  #rabbit-sprite[data-frame="3"] .frame-3 { display: block; }

  @keyframes cross-left-to-right {
    from { transform: translateX(calc(-100vw - 60px)); }
    to   { transform: translateX(calc(100vw + 60px)); }
  }

  @keyframes cross-right-to-left {
    from { transform: translateX(calc(100vw + 60px)) scaleX(-1); }
    to   { transform: translateX(calc(-100vw - 60px)) scaleX(-1); }
  }

  #pixel-buddy.run-ltr {
    animation: cross-left-to-right 7s linear forwards;
  }

  #pixel-buddy.run-rtl {
    animation: cross-right-to-left 7s linear forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    #pixel-buddy { display: none; }
  }
</style>

<script>
  const buddy = document.getElementById('pixel-buddy');
  const sprite = document.getElementById('rabbit-sprite');
  if (buddy && sprite) {
    let direction = 1;
    let frameInterval = null;

    function advanceFrame() {
      const current = parseInt(sprite.dataset.frame, 10);
      sprite.dataset.frame = String((current + 1) % 4);
    }

    function randomDelay() {
      return 5000 + Math.random() * 15000;
    }

    function scheduledRun() {
      sprite.dataset.frame = '0';
      const cls = direction > 0 ? 'run-ltr' : 'run-rtl';
      frameInterval = setInterval(advanceFrame, 125);
      buddy.classList.add(cls);
      direction *= -1;
      buddy.addEventListener('animationend', () => {
        clearInterval(frameInterval);
        buddy.classList.remove(cls);
        sprite.dataset.frame = '0';
        setTimeout(scheduledRun, randomDelay());
      }, { once: true });
    }

    setTimeout(scheduledRun, 2000 + Math.random() * 4000);
  }
</script>
