---
import TagPill from './TagPill.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags: string[];
  readingTime: number;
}

const { title, description, pubDate, slug, tags, readingTime } = Astro.props;

const formatted = pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<article class="post-card">
  <div class="meta">
    <time datetime={pubDate.toISOString()}>{formatted}</time>
    <span class="sep">·</span>
    <span>{readingTime} min read</span>
  </div>
  <h2><a href={`/blog/${slug}`}>{title}</a></h2>
  <p class="description">{description}</p>
  <div class="tags">
    {tags.map(t => <TagPill tag={t} />)}
  </div>
</article>

<style>
  .post-card {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--color-border);
    opacity: 0;
    animation: cardFadeIn 350ms var(--ease-out) forwards;
  }
  .post-card:last-child { border-bottom: none; }
  @keyframes cardFadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .post-card { animation: cardFadeIn 200ms ease forwards; }
    @keyframes cardFadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }
  .sep { opacity: 0.4; }

  h2 {
    font-family: var(--font-ui);
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }
  h2 a { color: var(--color-text); text-decoration: none; transition: color 150ms ease; }
  @media (hover: hover) and (pointer: fine) {
    h2 a:hover { color: var(--color-accent); }
  }

  .description {
    font-family: var(--font-body);
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
</style>
