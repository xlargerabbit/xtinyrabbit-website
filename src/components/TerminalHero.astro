---
---

<div class="terminal" role="img" aria-label="RPG character sheet in terminal style">
  <div class="chrome">
    <span class="dot red"></span>
    <span class="dot yellow"></span>
    <span class="dot green"></span>
    <span class="title">character.toml — bash</span>
  </div>
  <div class="body">
    <p class="cmd"><span class="prompt">$</span> cat character.toml</p>
    <div class="output">
      <p class="cmt"># player profile</p>
      <p><span class="k">name</span>    <span class="op">=</span> <span class="s">"xtinyrabbit"</span></p>
      <p><span class="k">class</span>   <span class="op">=</span> <span class="s">"systems engineer / ai tooling"</span></p>
      <p><span class="k">arc</span>     <span class="op">=</span> <span class="s">"QA → consultant → backend → FDE"</span></p>
      <br />
      <p class="cmt"># skills  [▓ = 1 point]</p>
      <p><span class="k">go              </span> <span class="op">=</span> <span class="bar"><span class="fill">▓▓▓▓▓▓▓▓▓</span><span class="empty">░</span></span></p>
      <p><span class="k">distributed_sys </span> <span class="op">=</span> <span class="bar"><span class="fill">▓▓▓▓▓▓▓▓</span><span class="empty">░░</span></span></p>
      <p><span class="k">devops_cicd     </span> <span class="op">=</span> <span class="bar"><span class="fill">▓▓▓▓▓▓▓▓</span><span class="empty">░░</span></span></p>
      <p><span class="k">system_design   </span> <span class="op">=</span> <span class="bar"><span class="fill">▓▓▓▓▓▓▓▓▓</span><span class="empty">░</span></span></p>
      <p><span class="k">observability   </span> <span class="op">=</span> <span class="bar"><span class="fill">▓▓▓▓▓▓▓▓</span><span class="empty">░░</span></span></p>
      <br />
      <p class="cmt"># traits</p>
      <p><span class="k">simplicity </span> <span class="op">=</span> <span class="bool">true</span></p>
      <p><span class="k">fail_fast  </span> <span class="op">=</span> <span class="bool">true</span></p>
      <p><span class="k">tdd        </span> <span class="op">=</span> <span class="bool">true</span></p>
    </div>
    <p class="cmd"><span class="prompt">$</span> <span class="cursor" aria-hidden="true">▋</span></p>
  </div>
</div>

<style>
  .terminal {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.65;
    background: #0d1117;
    border-radius: 8px;
    overflow: hidden;
    max-width: 540px;
    margin-block-end: 3rem;
    border: 1px solid #30363d;
  }

  .chrome {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: #161b22;
    border-bottom: 1px solid #30363d;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot.red    { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green  { background: #28c840; }

  .title {
    margin-left: 8px;
    color: #8b949e;
    font-size: 0.75rem;
    letter-spacing: 0.02em;
  }

  .body {
    padding: 16px 20px 14px;
    color: #e6edf3;
  }

  .cmd {
    margin: 0;
    white-space: pre;
  }

  .output {
    margin-block: 4px 8px;
    padding-left: 0;
  }

  .output p {
    margin: 0;
    white-space: pre;
  }

  .prompt { color: #7ee787; }
  .cmt    { color: #8b949e; }
  .k      { color: #e6edf3; }
  .op     { color: #79c0ff; }
  .s      { color: #a5d6ff; }
  .bool   { color: #ff7b72; }

  .bar .fill  { color: #7ee787; }
  .bar .empty { color: #30363d; }

  .cursor {
    color: #7ee787;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor { animation: none; }
  }
</style>
