---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = allPosts.slice(0, 5);
---

<BaseLayout title="Home">
  <div class="container">
    <section class="hero">
      <h1>xtinyrabbit</h1>
      <p>Reliable systems are harder than they look. Writing about systems programming, developer tooling, and the infrastructure of things that have to keep running.</p>
      <a href="/blog" class="cta">Read all posts →</a>
    </section>

    <section class="recent">
      <h2>Recent posts</h2>
      {recentPosts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          tags={post.data.tags}
          readingTime={Math.ceil((post.body ?? '').split(/\s+/).length / 200)}
        />
      ))}
    </section>
  </div>
</BaseLayout>

<style>
  .container { padding-block: 4rem; }

  .hero {
    max-width: 640px;
    margin-bottom: 5rem;
  }
  .hero h1 {
    font-family: var(--font-ui);
    font-size: var(--text-4xl);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    animation: heroFadeIn 450ms var(--ease-out) both;
  }
  .hero p {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: 2rem;
    animation: heroFadeIn 450ms var(--ease-out) both;
    animation-delay: 80ms;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    gap: 0.25rem;
    animation: heroFadeIn 450ms var(--ease-out) both;
    animation-delay: 150ms;
    transition: color 150ms ease;
  }
  @media (hover: hover) and (pointer: fine) {
    .cta:hover { text-decoration: underline; text-underline-offset: 3px; }
  }

  @keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .recent h2 {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .recent :global(.post-card:nth-child(1)) { animation-delay: 200ms; }
  .recent :global(.post-card:nth-child(2)) { animation-delay: 260ms; }
  .recent :global(.post-card:nth-child(3)) { animation-delay: 320ms; }
  .recent :global(.post-card:nth-child(4)) { animation-delay: 380ms; }
  .recent :global(.post-card:nth-child(5)) { animation-delay: 440ms; }

  @media (prefers-reduced-motion: reduce) {
    .hero h1, .hero p, .cta {
      animation: heroFadeIn 200ms ease both;
    }
    @keyframes heroFadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
  }
</style>
