---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagPill from '../../components/TagPill.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const tagCounts: Record<string, number> = {};
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  }
}

const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Topics" description="All topics on xtinyrabbit">
  <div class="container">
    <PageHeader
      title="Topics"
      subtitle={`${tags.length} topics across ${allPosts.length} posts`}
    />
    <div class="tag-grid">
      {tags.map(([tag, count]) => (
        <div class="tag-row">
          <TagPill tag={tag} />
          <span class="count">{count} {count === 1 ? 'post' : 'posts'}</span>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .container { padding-block: 3rem; }
  .tag-grid { display: flex; flex-direction: column; gap: 0.75rem; }
  .tag-row { display: flex; align-items: center; gap: 0.75rem; }
  .count { font-size: var(--text-sm); color: var(--color-text-muted); }
</style>
